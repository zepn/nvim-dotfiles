# -
# `!v expand('%:t')`
# =====
# ${2:Run Testbench}
#
# ${1:ZepN} <`!p
def format_comment(path):
  if path.startswith("Chae") or path.startswith(" "):
    retval = "chaelj@solidwt.co.kr"
  else:
    retval = "zepn.git@gmail.com"
  return retval

snip.rv = format_comment(t[1])
`> +`date +%Y.%m.%d`
# -



# =====
# 1. Set variables
# =====
set tb_top ${3}


# =====
# 2. Simulation
# =====
vsim -t 1ps           \
     -L work          \
     -voptargs="+acc" \
     work.${tb_top}


# =====
# 3. Create waves
# =====
#add wave -divider ""
#write format wave -window .main_pane.wave.interior.cs.body.pw.wf ./wave.do
#do wave.do


# =====
# 4. Run
# =====
#puts "Starting Simulation: ${tb_top}"
#run -all
$0
endsnippet

snippet if "if operator" b
if {${1}} {
  $0
}
endsnippet

snippet else "else operator" b
else {
  $0
}
endsnippet

snippet "if .. elseif" "if elseif operator" b
if {${1}} {
  ${3}
} elseif {${2:$1}} {
  $0
}
endsnippet

snippet while "while operator" b
while {${1:1}} {
	$0
}
endsnippet

snippet "for set i <= .." "for operator" b
for {set ${1:i} 0} {$1 <= ${2}} {incr $1} {
	$0
}
endsnippet

snippet "for set i >= .." "for operator" b
for {set ${1:i} 0} {$1 >= ${2}} {incr $1} {
	$0
}
endsnippet

snippet foreach "foreach operator" b
foreach ${1:i} ${2:list} {
  $0
}
endsnippet

snippet switch "switch operator" b
switch ${1} {
  ${2:0}
    {$0}

  default
    {}
}
endsnippet

snippet proc "procedure definition" b
proc ${1:name} {${2}} {
  $0
}
endsnippet
