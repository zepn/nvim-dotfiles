snippet __comment_compile=
#!/bin/tclsh
# -
# `!v expand('%:t')`
# =====
# ${2:Compile Testbench}
#
# ${1:ZepN} <`!p
def format_comment(path):
  if path.startswith("Chae") or path.startswith(" "):
    retval = "chaelj@solidwt.co.kr"
  else:
    retval = "zepn.git@gmail.com"
  return retval

snip.rv = format_comment(t[1])
`> +`date +%Y.%m.%d`
# -



# =====
# -. Procedure to compile files
# =====
proc compile_files {src_files src_dir target} {
  if { [string equal -nocase ${target} "HDL"] } {
    set version 93
  } elseif { [string equal -nocase ${target} "TB"] } {
    set version 2008
  } else {
    puts "Warning: Unknown target ${target}"
    return
  }

  foreach src_file ${src_files} {
    puts "Compiling ${target} file: ${src_file}"

    if { [string match "*.vhd" ${src_file}] || [string match "*.vhdl" ${src_file}] } {
      # Case for VHDL.
      vcom -quiet -${version} -work work ${src_dir}/${src_file}
    } elseif { [string match "*.v" ${src_file}] || [string match "*.sv" ${src_file}] } {
      # Case for Verilog/SystemVerilog.
      vlog -quiet -work work ${src_dir}/${src_file}
    } else {
      # Other cases.
      puts "Warning: Unknown file type for ${src_file}"
    }
  }
}


# =====
# 1. Set variables
# =====
set src_directory "../../SRCS"
set hdl_directory "${src_directory}/hdl/${3}"
set tb_directory "${src_directory}/tb/$3"

set hdl_files {
  ${4}
}
set tb_files {
  ${5}
}


# =====
# 2. Map libraries
# =====
vlib work
vmap work work


# =====
# 3. Compile files
# =====
compile_files ${hdl_files} ${hdl_directory} "HDL"
compile_files ${tb_files} ${tb_directory} "TB"
$0
endsnippet

snippet __comment_run=
